# Port for the proxy server to listen on
PORT=8080

# Database Driver: sqlite or mysql (defaults to sqlite)
DATABASE_DRIVER=sqlite

# SQLite database file path (used if driver is sqlite and DSN is empty)
DATABASE_FILE=database.db

# Database DSN connection string (required for mysql, optional for sqlite)
# DATABASE_DSN=username:password@tcp(localhost:3306)/dc_ai_api?parseTime=true

# Admin dashboard access password (leave empty to disable authorization and allow open access)
ADMIN_PASSWORD=your_secure_admin_password

# API Key of Tavily Search for web search grounding (optional, falls back to Wikipedia if not configured)
TAVILY_API_KEY=your_tavily_api_key_here

# Cloudflare Turnstile CAPTCHA Keys (optional, leave empty to bypass CAPTCHA check)
TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Text-to-Speech API Endpoint URL (optional, leave empty to disable TTS read aloud)
# TTS_API_URL=https://tiktok-tts.dabeecao.org

